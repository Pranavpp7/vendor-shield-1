# OpenRouter API (https://openrouter.ai/keys)
OPENROUTER_API_KEY=sk-or-xxxx
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct

# Server
SERVER_PORT=8000

# Vector DB (Qdrant — local Docker)
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Embedding Model
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIMENSIONS=1024

# Chunking
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Retrieval
RETRIEVAL_TOP_K=8

# Local Data Storage
DATA_DIR=data
UPLOAD_DIR=data/uploads

# Resend (https://resend.com) — for emailing PDF reports
RESEND_API_KEY=re_xxxx

# API key for x-api-key header (empty = dev mode, auth skipped)
API_KEY=vendorshield-dev-key-change-in-production

# Clerk Authentication (empty = dev mode, auth disabled)
# In production: paste your JWKS URL from Clerk Dashboard → API Keys → Advanced
CLERK_JWKS_URL=

# Single-tenant auth for exposed deployments (empty = dev mode, open)
API_KEY=
# Read-only public demo hosting (1 = mutations blocked, zero LLM spend)
DEMO_MODE=0
